<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            stylesheets="@../../css/login.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.project.financeflow.controllers.RegisterController">

    <children>

        <!-- Fundo -->

        <StackPane AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0"
                   AnchorPane.topAnchor="0.0">

            <children>

                <!-- Card -->

                <HBox maxHeight="560" maxWidth="950" minHeight="560" minWidth="950" styleClass="card">

                    <!-- Painel esquerdo -->

                    <VBox alignment="CENTER" prefWidth="290" spacing="25" styleClass="left-panel">

                        <children>

                            <Text styleClass="title-left" text="Olá novamente!" />

                            <Text styleClass="subtitle-left" text="Acesse sua conta agora" />

                            <Button fx:id="btnEntrar" onAction="#onEntrar" styleClass="btn-white" text="ENTRAR" />

                        </children>

                    </VBox>

                    <!-- Painel direito -->

                    <VBox alignment="CENTER" spacing="18" HBox.hgrow="ALWAYS">

                        <padding>
                            <Insets bottom="45" left="60" right="60" top="45" />
                        </padding>

                        <children>

                            <Text styleClass="title-right" text="CRIAR CONTA" />

                            <Region prefHeight="20" />

                            <!-- Nome -->

                            <HBox styleClass="input-box">

                                <children>

                                    <FontIcon iconLiteral="fas-user" styleClass="icon"/>

                                    <TextField fx:id="txtNome" promptText="NOME" styleClass="text-field-custom" />

                                </children>

                            </HBox>

                            <!-- Email -->

                            <HBox styleClass="input-box">

                                <children>

                                    <FontIcon iconLiteral="fas-envelope" styleClass="icon"/>

                                    <TextField fx:id="txtEmail" promptText="E-MAIL" styleClass="text-field-custom" />

                                </children>

                            </HBox>

                            <!-- Senha -->

                            <HBox styleClass="input-box">

                                <children>

                                    <FontIcon iconLiteral="fas-lock" styleClass="icon"/>

                                    <PasswordField fx:id="txtPassword" promptText="SENHA" styleClass="text-field-custom" />

                                </children>

                            </HBox>

                            <Region prefHeight="20" />

                            <Button fx:id="btnCadastrar" onAction="#onCadastrar" styleClass="btn-green" text="CADASTRAR" />

                        </children>

                    </VBox>

                </HBox>

            </children>

        </StackPane>

    </children>

</AnchorPane>
